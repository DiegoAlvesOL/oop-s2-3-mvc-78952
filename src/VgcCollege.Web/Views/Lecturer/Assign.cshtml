@model VgcCollege.Web.Models.AssignLecturerViewModel

@{
    ViewData["Title"] = "Assign to course";
}

<h2 class="mb-1">Assign to course</h2>
<p class="text-muted mb-4">Lecturer: <strong>@Model.LecturerName</strong></p>

<div class="col-md-5">
    <form asp-action="Assign" method="post">
        <input type="hidden" asp-for="LecturerProfileId" />
        <input type="hidden" asp-for="LecturerName" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="CourseId" class="form-label"></label>
            <select asp-for="CourseId" asp-items="Model.AvailableCourses" class="form-select">
                <option value="">-- Select course --</option>
            </select>
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="IsTutor" class="form-check-input" />
            <label asp-for="IsTutor" class="form-check-label"></label>
            <div class="form-text">Tutors have access to student contact details.</div>
        </div>

        <button type="submit" class="btn btn-primary">Assign</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}