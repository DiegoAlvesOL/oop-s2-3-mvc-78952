@model IEnumerable<VgcCollege.Domain.Entities.LecturerProfile>

@{
    ViewData["Title"] = "Lecturers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Lecturers</h2>
    <a asp-action="Create" class="btn btn-primary">Add lecturer</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var lecturer in Model)
    {
        <tr>
            <td>@lecturer.FirstName @lecturer.LastName</td>
            <td>@lecturer.Email</td>
            <td>@lecturer.Phone</td>
            <td>
                <a asp-action="Assign" asp-route-id="@lecturer.Id" class="btn btn-sm btn-outline-primary">Assign to course</a>
                <a asp-action="Edit" asp-route-id="@lecturer.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                <form asp-action="Delete" asp-route-id="@lecturer.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Are you sure you want to delete this lecturer profile?')">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>