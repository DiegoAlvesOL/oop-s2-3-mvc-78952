@model IEnumerable<VgcCollege.Domain.Entities.CourseEnrolment>

@{
    ViewData["Title"] = "Enrolments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Enrolments</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Enrol student</a>
    }
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
        <th>Student</th>
        <th>Course</th>
        <th>Branch</th>
        <th>Enrol date</th>
        <th>Status</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var enrolment in Model)
    {
        <tr>
            <td>@enrolment.Student?.FirstName @enrolment.Student?.LastName</td>
            <td>@enrolment.Course?.CourseName</td>
            <td>@enrolment.Course?.Branch?.BranchName</td>
            <td>@enrolment.EnrolDate.ToString("dd/MM/yyyy")</td>
            <td>@enrolment.Status</td>
        </tr>
    }
    </tbody>
</table>