@model IEnumerable<VgcCollege.Domain.Entities.CourseEnrolment>

@{
    ViewData["Title"] = "Assignment results";
    var assignment = ViewBag.Assignment as VgcCollege.Domain.Entities.Assignment;
    var existingResults = ViewBag.ExistingResults as Dictionary<int, VgcCollege.Domain.Entities.AssignmentResult>
                          ?? new Dictionary<int, VgcCollege.Domain.Entities.AssignmentResult>();
}

<div class="d-flex justify-content-between align-items-center mb-1">
    <h2 class="mb-0">Results</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to gradebook</a>
</div>
<p class="text-muted mb-4">
    Assignment: <strong>@assignment?.Title</strong> —
    Max score: <strong>@assignment?.MaxScore</strong>
</p>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>Student</th>
            <th>Score</th>
            <th>Feedback</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var enrolment in Model)
        {
            var hasResult = existingResults.TryGetValue(enrolment.StudentProfileId, out var result);
            <tr>
                <td>@enrolment.Student?.FirstName @enrolment.Student?.LastName</td>
                <td>
                    @if (hasResult)
                    {
                        <span class="badge bg-success">@result!.Score / @assignment?.MaxScore</span>
                    }
                    else
                    {
                        <span class="text-muted">Not graded</span>
                    }
                </td>
                <td>@(hasResult ? result!.Feedback : "—")</td>
                <td>
                    @if (!hasResult)
                    {
                        <a asp-action="SetResult"
                           asp-route-assignmentId="@assignment?.Id"
                           asp-route-studentProfileId="@enrolment.StudentProfileId"
                           class="btn btn-sm btn-outline-primary">Set result</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>