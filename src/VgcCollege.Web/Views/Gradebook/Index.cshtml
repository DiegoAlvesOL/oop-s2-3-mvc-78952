@model IEnumerable<VgcCollege.Domain.Entities.Assignment>

@{
    ViewData["Title"] = "Gradebook";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Gradebook</h2>
    @if (User.IsInRole("Lecturer"))
    {
        <a asp-action="Create" asp-route-courseId="@ViewBag.CurrentCourseId" class="btn btn-primary">
            Add assignment
        </a>
    }
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
        <th>Title</th>
        <th>Max score</th>
        <th>Due date</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var assignment in Model)
    {
        <tr>
            <td>@assignment.Title</td>
            <td>@assignment.MaxScore</td>
            <td>@assignment.DueDate.ToString("dd/MM/yyyy")</td>
            <td>
                <a asp-action="Results" asp-route-assignmentId="@assignment.Id"
                   class="btn btn-sm btn-outline-secondary">View results</a>
            </td>
        </tr>
    }
    </tbody>
</table>