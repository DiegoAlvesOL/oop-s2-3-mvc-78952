@model IEnumerable<VgcCollege.Domain.Entities.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Courses</h2>
    <a asp-action="Create" class="btn btn-primary">Add course</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
        <th>Course name</th>
        <th>Branch</th>
        <th>Start date</th>
        <th>End date</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.CourseName</td>
            <td>@course.Branch.BranchName</td>
            <td>@course.StartDate.ToString("dd/MM/yyyy")</td>
            <td>@course.EndDate.ToString("dd/MM/yyyy")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                <form asp-action="Delete" asp-route-id="@course.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Are you sure you want to delete this course?')">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>