@model IEnumerable<VgcCollege.Domain.Entities.StudentProfile>

@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Students</h2>
    <a asp-action="Create" class="btn btn-primary">Add student</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
        <th>Student number</th>
        <th>Name</th>
        <th>Email</th>
        <th>City</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var student in Model)
    {
        <tr>
            <td>@student.StudentNumber</td>
            <td>@student.FirstName @student.LastName</td>
            <td>@student.Email</td>
            <td>@student.City</td>
            <td>
                <a asp-action="Enrolments" asp-route-id="@student.Id"
                   class="btn btn-sm btn-outline-primary">Enrolments</a>
                <a asp-action="Edit" asp-route-id="@student.Id"
                   class="btn btn-sm btn-outline-secondary">Edit</a>
                <form asp-action="Delete" asp-route-id="@student.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Are you sure you want to delete this student profile?')">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>