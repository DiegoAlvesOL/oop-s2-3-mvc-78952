@model VgcCollege.Web.Models.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <h2 class="mb-2">Something went wrong</h2>
    <p class="text-muted mb-4">
        An unexpected error occurred. Please try again or return to the home page.
    </p>
    @if (Model?.ShowRequestId == true)
    {
        <p class="text-muted small mb-4">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Return to home</a>
</div>