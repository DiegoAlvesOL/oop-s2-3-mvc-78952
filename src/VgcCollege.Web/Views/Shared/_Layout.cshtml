<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — VGC College</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom border-secondary">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    VGC College
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Branch" asp-action="Index">Branches</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Student" asp-action="Index">Students</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Lecturer" asp-action="Index">Lecturers</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Enrolment" asp-action="Index">Enrolments</a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button"
                                       data-bs-toggle="dropdown">Exams</a>
                                    <ul class="dropdown-menu dropdown-menu-dark">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Exam"
                                               asp-action="Index" asp-route-courseId="1">
                                                View by course
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }

                            @if (User.IsInRole("Lecturer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Gradebook" asp-action="Index">Gradebook</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Enrolment" asp-action="Index">My students</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Exam"
                                       asp-action="Index" asp-route-courseId="1">Exams</a>
                                </li>
                            }

                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Enrolment" asp-action="Index">My enrolments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Gradebook" asp-action="Index">My grades</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Exam" asp-action="MyResults">My results</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light opacity-75">
                                    @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-light ms-2 my-1">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 mb-4">
        @RenderBody()
    </div>

    <footer class="border-top py-3 mt-auto bg-light">
        <div class="container text-center text-muted small">
            VGC College Academic Management System &copy; @DateTime.Now.Year
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>