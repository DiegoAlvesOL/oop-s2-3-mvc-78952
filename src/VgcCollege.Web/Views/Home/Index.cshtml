@{
    ViewData["Title"] = "Home";
}

<div class="px-2 py-4">

    @if (User.IsInRole("Admin"))
    {
        <h2 class="mb-1">Welcome, Administrator</h2>
        <p class="text-muted mb-4">Manage the college from the navigation menu above.</p>

        <div class="row g-3">
            <div class="col-md-3">
                <a asp-controller="Branch" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">Branches</h6>
                            <p class="card-text text-muted small">Manage college branches and locations.</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a asp-controller="Course" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">Courses</h6>
                            <p class="card-text text-muted small">View and manage all courses.</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a asp-controller="Student" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">Students</h6>
                            <p class="card-text text-muted small">View and manage student profiles.</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a asp-controller="Lecturer" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">Lecturers</h6>
                            <p class="card-text text-muted small">View and manage lecturer profiles.</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    }

    @if (User.IsInRole("Lecturer"))
    {
        <h2 class="mb-1">Welcome back</h2>
        <p class="text-muted mb-4">Access your courses and student records from the menu above.</p>

        <div class="row g-3">
            <div class="col-md-4">
                <a asp-controller="Gradebook" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">Gradebook</h6>
                            <p class="card-text text-muted small">View and launch assignment results.</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Enrolment" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">My students</h6>
                            <p class="card-text text-muted small">View enrolments for your courses.</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Exam" asp-action="Index" asp-route-courseId="1" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">Exams</h6>
                            <p class="card-text text-muted small">Manage exams and release results.</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    }

    @if (User.IsInRole("Student"))
    {
        <h2 class="mb-1">Welcome back</h2>
        <p class="text-muted mb-4">Check your enrolments, grades and exam results from the menu above.</p>

        <div class="row g-3">
            <div class="col-md-4">
                <a asp-controller="Enrolment" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">My enrolments</h6>
                            <p class="card-text text-muted small">View your current course enrolments.</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Gradebook" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">My grades</h6>
                            <p class="card-text text-muted small">View your assignment results and feedback.</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Exam" asp-action="MyResults" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">My exam results</h6>
                            <p class="card-text text-muted small">View released exam results.</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    }

    @if (User.Identity?.IsAuthenticated == false)
    {
        <div class="text-center py-5">
            <h2 class="mb-3">VGC College Academic Management System</h2>
            <p class="text-muted mb-4">Please log in to access the system.</p>
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-4">Login</a>
        </div>
    }

</div>